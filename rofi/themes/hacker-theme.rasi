/* Hacker Theme for Rofi - Matching Waybar Aesthetic */

* {
    bg-col: #1a1a1a;
    bg-col-light: #2a2a2a;
    border-col: transparent;
    selected-col: #333333;
    blue: #ffffff;
    fg-col: #ffffff;
    fg-col2: #cccccc;
    grey: #666666;

    width: 600;
    font: "JetBrainsMono Nerd Font 12";
}

element-text, element-icon, mode-switcher {
    background-color: inherit;
    text-color: inherit;
}

window {
    height: 360px;
    border: 0px;
    border-color: @border-col;
    background-color: rgba(26, 26, 26, 0.95);
    border-radius: 12px;
    transparency: "real";
}

mainbox {
    background-color: transparent;
}

inputbar {
    children: [prompt,entry];
    background-color: rgba(42, 42, 42, 0.8);
    border-radius: 8px;
    padding: 2px;
    margin: 15px;
}

prompt {
    background-color: transparent;
    padding: 8px 12px;
    text-color: @fg-col;
    border-radius: 6px;
}

textbox-prompt-colon {
    expand: false;
    str: ":";
}

entry {
    padding: 8px 12px;
    text-color: @fg-col;
    background-color: transparent;
    placeholder-color: @grey;
}

listview {
    border: 0px;
    padding: 0px 15px 15px 15px;
    margin: 0px;
    columns: 1;
    lines: 8;
    background-color: transparent;
}

element {
    padding: 8px 12px;
    background-color: transparent;
    text-color: @fg-col;
    border-radius: 6px;
    margin: 2px 0px;
}

element-icon {
    size: 24px;
    margin: 0px 8px 0px 0px;
}

element selected {
    background-color: @selected-col;
    text-color: @fg-col;
}

mode-switcher {
    spacing: 0;
    background-color: rgba(42, 42, 42, 0.8);
    margin: 0px 15px 15px 15px;
    border-radius: 8px;
}

button {
    padding: 10px 15px;
    background-color: transparent;
    text-color: @grey;
    vertical-align: 0.5;
    horizontal-align: 0.5;
    border-radius: 6px;
}

button selected {
    background-color: rgba(255, 255, 255, 0.1);
    text-color: @blue;
}

message {
    background-color: transparent;
    margin: 2px;
    padding: 2px;
    border-radius: 5px;
}

textbox {
    padding: 6px;
    margin: 20px 0px 0px 20px;
    text-color: @blue;
    background-color: transparent;
}
